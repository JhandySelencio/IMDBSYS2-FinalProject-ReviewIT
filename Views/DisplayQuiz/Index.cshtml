@model ReviewIT_FinalProject_IMDBSYS2.Models.Quiz

@{
    ViewData["Title"] = "Quiz Summary";
}

<div class="container my-5">

    <!-- Quiz Meta Details Header Card -->
    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-3">
                <div>
                    <span class="badge bg-primary px-3 py-2 mb-2">
                        <i class="fa-solid fa-tags me-1"></i> @Model.Category?.CategoryType
                    </span>
                    <h1 class="display-5 fw-bold text-dark mb-0">@Model.Title</h1>
                </div>
                <!-- Heart Ratio Display -->
                @{
                    // Read the server value passed from the controller action
                    bool initialHeartedState = ViewBag.IsHearted ?? false;
                }
                <div class="bg-light p-3 rounded-3 border text-center min-w-md-150">
                    <button id="heartBtn"
                            class="btn @(initialHeartedState ? "btn-danger text-white" : "btn-outline-danger border-0") fw-bold d-flex align-items-center justify-content-center gap-2 mx-auto"
                            data-quiz-id="@Model.QuizId"
                            data-is-hearted="@initialHeartedState.ToString().ToLower()">

                        <i id="heartIcon" class="@(initialHeartedState ? "fa-solid" :   "fa-regular") fa-heart fs-3 text-danger"></i>
                        <span id="heartCountText" class="fs-4">@Model.HeartRatio</span>
                    </button>
                </div>
            </div>

            <hr class="text-muted">

            <!-- Timestamps & Total Indicator Row -->
            <div class="row text-muted small g-3">
                <div class="col-sm-6 col-md-4">
                    <i class="fa-regular fa-calendar-plus me-2"></i><strong>Created:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy")
                </div>
                <div class="col-sm-6 col-md-4">
                    <i class="fa-solid fa-pen-to-square me-2"></i><strong>Last Updated:</strong> @Model.UpdatedAt.ToString("MMMM dd, yyyy")
                </div>
            </div>
        </div>
    </div>

    <div class="mb-4 d-flex justify-content-between align-items-center">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary fw-semibold">
            <i class="fa-solid fa-arrow-left me-1"></i> Back to Home
        </a>
        <!--Flashcard button-->
        <a asp-controller="DisplayQuiz" asp-action="Flashcards" asp-route-quizId="@Model.QuizId" class="btn btn-warning fw-bold shadow-sm">
            <i class="fa-solid fa-layer-group me-2"></i> Study Flashcards
        </a>
        <!--Test Quiz button-->
        <a asp-controller="DisplayQuiz" asp-action="TestQuiz" asp-route-quizId="@Model.QuizId" class="btn btn-primary fw-bold shadow-sm">
            <i class="fa-solid fa-file-pen me-2"></i> Take Test
        </a>
    </div>

    <!-- Dynamic Total Question Counter Text Box -->
    <div class="alert alert-info border-0 shadow-sm d-flex align-items-center p-3 mb-4" role="alert">
        <i class="fa-solid fa-circle-info fa-xl text-info me-3"></i>
        <div class="fw-semibold">
            This quiz contains a total of <strong class="fs-5 text-dark">@Model.Questions.Count</strong> active questions.
        </div>
    </div>

    <!-- Question and Filtered Key List -->
    <h3 class="h4 text-dark fw-bold mb-3 mt-5">
        <i class="fa-solid fa-list-check text-success me-2"></i> Answer Key Sheet
    </h3>

    @if (!Model.Questions.Any())
    {
        <div class="card border-0 shadow-sm p-4 text-center text-muted">
            <i class="fa-regular fa-folder-open fa-2x mb-2"></i>
            There are currently no active questions associated with this quiz.
        </div>
    }
    else
    {
        int itemIndex = 1;
        <div class="d-flex flex-column gap-3">
            @foreach (var question in Model.Questions)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <!-- Question Text -->
                        <h5 class="fw-bold text-dark mb-3">
                            <span class="text-secondary me-1">@itemIndex.</span> @question.QuestionText
                        </h5>

                        <!-- Filtered Correct Choice Box -->
                        <div class="ps-3 border-start border-success border-3 bg-light py-2 rounded-end">
                            <span class="small font-monospace text-success fw-bold d-block mb-1">CORRECT ANSWER:</span>

                            @{
                                var correctChoices = question.Choices.Where(c => c.IsCorrect == true).ToList();
                            }

                            @if (correctChoices.Any())
                            {
                                foreach (var choice in correctChoices)
                                {
                                    <div class="text-dark fw-semibold d-flex align-items-center gap-2">
                                        <i class="fa-solid fa-circle-check text-success"></i> @choice.ChoiceText
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted small fst-italic">
                                    <i class="fa-solid fa-triangle-exclamation text-warning me-1"></i> No correct answer has been flagged for this question.
                                </div>
                            }
                        </div>
                    </div>
                </div>
                itemIndex++;
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        document.getElementById('heartBtn').addEventListener('click', function () {
            const button = this;
            const icon = document.getElementById('heartIcon');
            const countText = document.getElementById('heartCountText');

            // Get data parameters from HTML attributes
            const quizId = button.getAttribute('data-quiz-id');
            const isHearted = button.getAttribute('data-is-hearted') === 'true';

            // Send silent request to backend controller via AJAX POST
            fetch(`/DisplayQuiz/ToggleHeart?quizId=${quizId}&isHearted=${isHearted}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // 1. Update the printed number on screen
                    countText.innerText = data.newCount;

                    // 2. Toggle the visual state of the button
                    if (isHearted) {
                        // Changed to UN-HEARTED state
                        button.setAttribute('data-is-hearted', 'false');
                        icon.classList.replace('fa-solid', 'fa-regular'); // Makes heart empty
                        button.classList.remove('btn-danger', 'text-white');
                        button.classList.add('btn-outline-danger');
                    } else {
                        // Changed to HEARTED state
                        button.setAttribute('data-is-hearted', 'true');
                        icon.classList.replace('fa-regular', 'fa-solid'); // Makes heart filled
                        button.classList.remove('btn-outline-danger');
                        button.classList.add('btn-danger', 'text-white'); // Adds red background highlight
                    }
                }
            })
            .catch(error => console.error('Error handling heart click submission:', error));
        });
    </script>
}