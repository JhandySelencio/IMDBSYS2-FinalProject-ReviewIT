@model ReviewIT_FinalProject_IMDBSYS2.Models.Quiz

@{
    ViewData["Title"] = "Test Mode - " + Model.Title;
}

<div class="container my-5 max-w-md-800 mx-auto">
    <!-- Test Header -->
    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-body p-4 text-center">
            <span class="badge bg-primary mb-2 fs-5">
                <i class="fa-solid fa-tags me-1"></i>
                @Model.Category?.CategoryType</span>
            <h1 class="fw-bold text-dark mb-3">@Model.Title</h1>
            <div class="d-flex justify-content-center gap-4 text-muted fw-semibold">
                <span><i class="fa-solid fa-circle-question me-1"></i> @Model.Questions.Count Questions</span>
            </div>
        </div>
    </div>

    <!-- The Exam Form -->
    <!-- Note: We are setting up a POST form here to prepare for when you want to grade the test! -->
    <form asp-action="SubmitTest" method="post">
        <input type="hidden" name="QuizId" value="@Model.QuizId" />

        @{
            int questionNumber = 1;
        }

        @foreach (var question in Model.Questions)
        {
            <div class="card shadow border-0 mb-4 bg-white">
                <div class="card-header bg-primary rounded-top-4 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-light">
                        <span class="text-light me-2">@questionNumber.</span> @question.QuestionText
                    </h5>
                </div>

                <div class="card-body p-4">
                    <div class="d-flex flex-column gap-3">

                        @if (question.QuestionTypeId == 1)
                        {
                            <!-- IDENTIFICATION: Text Input -->
                            <div class="form-group">
                                <label class="form-label text-muted small">Type your answer below:</label>
                                <input type="text"
                                       name="question_@question.QuestionId"
                                       class="form-control form-control-lg border-primary"
                                       placeholder="Enter your exact answer..."
                                       autocomplete="off"
                                       required />
                            </div>
                        }
                        else
                        {
                            <!-- MULTIPLE CHOICE & TRUE/FALSE: Radio Buttons -->
                            @foreach (var choice in question.Choices)
                            {
                                <label class="form-check border rounded p-3 cursor-pointer hover-bg-light transition-all">
                                    <input class="form-check-input ms-1 me-3"
                                           type="radio"
                                           name="question_@question.QuestionId"
                                           value="@choice.ChoiceId"
                                           required>
                                    <span class="form-check-label fs-5">
                                        @choice.ChoiceText
                                    </span>
                                </label>
                            }
                        }
                    </div>
                </div>
            </div>
            questionNumber++;
        }

        <!-- Update the Submit Button to actually submit the form -->
        <div class="card shadow-sm border-0 bg-white p-4 text-center mt-5">
            <h5 class="text-muted mb-3">Ready to see how you did?</h5>
            <div class="d-flex justify-content-center gap-3">
                <a asp-action="Index" asp-route-quizId="@Model.QuizId" class="btn btn-secondary px-4 fw-semibold">Cancel Test</a>

                <!-- Changed type="button" to type="submit" -->
                <button type="submit" class="btn btn-success px-5 fw-bold">
                    <i class="fa-solid fa-check me-2"></i> Submit Answers
                </button>
            </div>
        </div>
    </form>
</div>

<style>
    /* Minor CSS tweaks to make the radio buttons look like clickable blocks */
    .cursor-pointer {
        cursor: pointer;
    }

    .hover-bg-light:hover {
        background-color: #f8f9fa;
        border-color: #dee2e6 !important;
    }

    .transition-all {
        transition: all 0.2s ease-in-out;
    }

    /* Hide default radio button slightly and make it larger */
    .form-check-input {
        width: 1.5em;
        height: 1.5em;
        margin-top: 0.15em;
        cursor: pointer;
    }
</style>