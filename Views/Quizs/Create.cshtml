@model ReviewIT_FinalProject_IMDBSYS2.Models.Quiz

@{
    ViewData["Title"] = "Create";
}

<h1 class="fw-bold text-primary text-center">Creating a new Quiz Set!</h1>

<div class="row border border-primary border-2 rounded-3 p-3 shadow">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group ">
                <label asp-for="Title" class="control-label fw-bold fs-4 text-primary">Enter the Title</label>
                <input asp-for="Title" class="form-control mt-1" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="form-group pt-2">
                <label asp-for="CategoryId" class="control-label fw-bold fs-4 text-primary">Choose a category type</label>
                <select asp-for="CategoryId" class ="form-control mt-1" asp-items="ViewBag.CategoryId"></select>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary fw-bold" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-secondary fw-bold m-2">
        <i class="fa-solid fa-angle-left text-light"></i> Back to List
    </a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
