@model ReviewIT_FinalProject_IMDBSYS2.Models.Question

@{
    ViewData["Title"] = "Edit";
}

<h1 class="fw-bold text-primary text-center pb-2">Updating the Questions</h1>

<div class="row border border-primary border-2 rounded-3 p-3 shadow">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="QuestionId" />
            <input type="hidden" asp-for="QuizId" />
            <div class="form-group">
                <label asp-for="QuestionText" class="control-label fw-bold fs-4 text-primary">Change the Question</label>
                <input asp-for="QuestionText" class="form-control mt-1" />
                <span asp-validation-for="QuestionText" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StatusId" class="control-label fw-bold fs-4 text-primary">Change the Status Type</label>
                <select asp-for="StatusId" class="form-control mt-1" asp-items="ViewBag.StatusId"></select>
                <span asp-validation-for="StatusId" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Save Changes" class="btn btn-primary fw-bold" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" asp-route-quizId="@ViewBag.QuizId" class="btn btn-secondary fw-bold m-2">
        <i class="fa-solid fa-angle-left text-light"></i> Back to List
    </a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
