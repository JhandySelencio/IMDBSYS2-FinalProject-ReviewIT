@model IEnumerable<ReviewIT_FinalProject_IMDBSYS2.Models.Quiz>

<div class="container my-5">
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h1 class="fw-bold text-primary mb-1"><i class="fa-solid fa-compass text-primary me-2"></i>Browse Quizzes</h1>
        </div>
        <div class="col-md-6">
            <form asp-controller="Home" asp-action="Browse" method="get" class="input-group">
                <input type="text" name="searchString" class="form-control border-2 border-primary" placeholder="Search by quiz title or category..." value="@ViewData["CurrentFilter"]" />
                <button class="btn btn-primary fw-semibold" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
            </form>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var quiz in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                        <span class="badge bg-info text-dark">
                            <i class="fa-solid fa-tags me-1"></i>
                            @quiz.Category?.CategoryType</span>
                        <span class="badge bg-secondary">
                            <i class="fa-solid fa-circle-question" style="color: rgb(255, 255, 255);"></i>
                            Questions @quiz.Questions.Count
                        </span>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@quiz.Title</h5>
                        <div class="mt-3 py-2 px-3 bg-light rounded-2 d-flex justify-content-between align-items-center">
                            <small class="text-muted fw-semibold">
                                <i class="fa-regular fa-calendar-days" style="color:dimgrey"></i>
                                @quiz.CreatedAt.ToString("MMM dd, yyyy")
                            </small>
                            <span class="fw-bold text-danger"><i class="fa-solid fa-heart fa-beat"></i> @quiz.HeartRatio</span>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 pb-3">
                        <a asp-controller="DisplayQuiz" asp-action="Index" asp-route-quizId="@quiz.QuizId" class="btn btn-outline-primary w-100 fw-bold">View Detail <i class="fa-solid fa-right-long text-primary"></i></a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>